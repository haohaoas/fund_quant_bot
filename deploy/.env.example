# Copy this file to deploy/.env before first deploy.
# cp deploy/.env.example deploy/.env

# LLM key used by ai_picker/news_sentiment
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SEC=5
DEEPSEEK_MAX_TOKENS=180
WATCHLIST_AI_MODE=fast
WATCHLIST_ANALYZE_USE_AI=1
WATCHLIST_ANALYZE_SIGNAL_TIMEOUT_SEC=5

# Optional market data provider token
TUSHARE_TOKEN=

# Optional provider controls
FUND_BOARD_PROVIDER=akshare
FUND_PRICE_PROVIDER=auto

# 2G server memory tuning (recommended defaults)
PORTFOLIO_ENRICH_MAX_WORKERS=2
WATCHLIST_ENRICH_MAX_WORKERS=2
SECTOR_CACHE_MAX_KEYS=40
FUNDGZ_CACHE_MAX=300
SETTLED_NAV_CACHE_MAX=500
FUND123_KEY_CACHE_MAX=300
FUND123_FAIL_CACHE_MAX=300
FUND123_TREND_CACHE_MAX=300

# Optional Biying quote provider
# Set your licence to enable quote_source=biying
BIYING_LICENCE=
BIYING_API_BASE=http://api.biyingapi.com

# CORS (comma separated), for example:
# ALLOW_ORIGINS=https://your-domain.com,https://www.your-domain.com
ALLOW_ORIGINS=*
